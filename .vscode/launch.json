{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Flask",
      "type": "python",
      "request": "launch",
      "module": "flask",
      "env": {
        "FLASK_APP": "backend/app.py",
        "FLASK_ENV": "development"
      },
      "args": ["run", "--no-debugger", "--host=0.0.0.0", "--port=5000"],
      "jinja": true,
      "cwd": "${workspaceFolder}"
    }
  ]
}
